{
  "manifest_version": 3,
  "name": "Florilegio",
  "version": "1.0",
  "description": "Save bookmarks to your personal Florilegio API",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save bookmark"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "florilegio@personal",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
